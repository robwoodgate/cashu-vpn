{
  "name": "cashu-vpn",
  "version": "0.2.0",
  "description": "Sell short-lived WireGuard VPN access for Cashu ecash — non-custodial, no accounts",
  "type": "module",
  "license": "MIT",
  "author": "Rob Woodgate",
  "homepage": "https://github.com/robwoodgate/cashu-vpn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robwoodgate/cashu-vpn.git"
  },
  "bugs": {
    "url": "https://github.com/robwoodgate/cashu-vpn/issues"
  },
  "keywords": [
    "cashu",
    "ecash",
    "wireguard",
    "vpn",
    "lightning",
    "bitcoin",
    "nut-18",
    "nostr"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json && npm run build:client",
    "build:client": "esbuild src/client.ts --bundle --minify --format=iife --platform=browser --loader:.svg=dataurl --outfile=dist/public/client.js",
    "test": "npm run build --silent && node --test $(find dist/test -name '*.test.js')",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "start": "node dist/src/main.js",
    "start:env": "node --env-file=.env dist/src/main.js",
    "update": "bash scripts/update.sh",
    "keygen": "node dist/src/keygen.js",
    "discover": "node dist/src/discover.js",
    "sweep": "node dist/src/sweep.js",
    "sweep:remote": "bash scripts/sweep-remote.sh",
    "prune": "node dist/src/sweep.js --prune"
  },
  "engines": {
    "node": ">=22.4.0"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^4.6.0",
    "@scure/bip32": "^2.2.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.30",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0"
  }
}
