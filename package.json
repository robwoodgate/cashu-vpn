    "node": ">=20"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^8.57.1",
    "typescript": "^5.8.3"
  }
}
