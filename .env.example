# cashu-vpn configuration. Copy this to `.env` and fill it in.
#
#   cp .env.example .env
#
# `.env` is read by the systemd service (scripts/install-systemd.sh) and, if you
# run the daemon directly on Node >= 20.6, by `npm run start:env`.

# --- Mode ------------------------------------------------------------------
# `live` takes payment and manages real WireGuard peers. Omit (or `dry-run`) to
# try everything locally with no payment and no host changes.
MODE=live

# --- WireGuard -------------------------------------------------------------
WG_INTERFACE=wg0
# Both values come from: npm run discover wg0
SERVER_PUBLIC_KEY=
WG_ENDPOINT=your.server.ip:51820

# --- Payout key ------------------------------------------------------------
# Your BIP32 xpub. Generate the pair OFFLINE with `npm run keygen` and keep the
# xprv off this box.
OPERATOR_XPUB=

# --- Pricing & mints -------------------------------------------------------
ACCEPTED_MINTS=https://mint.minibits.cash/Bitcoin
PRICE_SATS=1000
MINT_UNIT=sat
# Lease length in milliseconds (86400000 = 1 day).
LEASE_DURATION_MS=86400000

# --- Optional buyer-page notice + terms ------------------------------------
# NOTICE shows as a banner on the page and in /info (like a mint MOTD).
# TERMS_URL adds an acceptable-use / terms link. Both optional.
NOTICE=
TERMS_URL=

# --- Public address --------------------------------------------------------
# Your public HTTPS URL. Tells paying wallets where to deliver. Set this when
# you run behind a reverse proxy.
PUBLIC_BASE_URL=https://vpn.example.com

# --- Persistence (state lives under ./state) -------------------------------
PROOFS_PATH=./state/proofs.json
PEER_LEDGER_PATH=./state/peers.json
ORDERS_PATH=./state/orders.json
LOCK_COUNTER_PATH=./state/locks.json
# Expired-peer cleanup interval (ms). On by default; set 0 to disable. The same
# tick also forgets records older than RETAIN_EXPIRED_MS.
CLEANUP_INTERVAL_MS=60000
# How long expired leases/orders are kept before being forgotten (ms). Bounds
# file growth and memory. 0 keeps everything.
RETAIN_EXPIRED_MS=86400000

# --- Rate limiting (per IP on /purchase) -----------------------------------
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# --- Networking ------------------------------------------------------------
HOST=127.0.0.1
PORT=3087

# --- Optional: let the installer add a Caddy HTTPS site --------------------
# Set to your domain (e.g. vpn.example.com) and scripts/install-systemd.sh will
# add a reverse-proxy site to Caddy. Leave blank to skip and configure TLS
# yourself.
DOMAIN=
